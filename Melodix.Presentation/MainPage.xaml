<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:Melodix.Application.DTOs;assembly=Melodix.Application"
             xmlns:viewModels="clr-namespace:Melodix.Presentation.ViewModels"
             x:Class="Melodix.Presentation.MainPage"
             x:DataType="viewModels:MainPageViewModel"
             Title="Melodix">
    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Agregar carpeta" Command="{Binding PickFolderCommand}" />
        <ToolbarItem Text="Reescanear" Command="{Binding RefreshLibraryCommand}" />
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto"
          RowSpacing="0"
          BackgroundColor="{StaticResource Black}">
        <Grid Grid.Row="0"
              Margin="24,18,24,18">
            <Border IsVisible="{Binding IsLibraryEmpty}"
                    BackgroundColor="{StaticResource Gray950}"
                    Padding="28"
                    Stroke="{StaticResource Gray600Brush}">
                <VerticalStackLayout MaximumWidthRequest="460"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="18">
                    <Border Background="{StaticResource Gray900}"
                            Padding="18"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 24">
                        <Label Text="&#x266A;"
                               HorizontalTextAlignment="Center"
                               FontSize="36"
                               TextColor="{StaticResource Primary}" />
                    </Border>

                    <Label Text="{Binding EmptyStateTitle}"
                           FontFamily="OpenSansSemibold"
                           FontSize="24"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource White}" />

                    <Label Text="{Binding EmptyStateMessage}"
                           FontSize="14"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource Gray300}" />

                    <Button Text="Agregar carpeta"
                            Command="{Binding PickFolderCommand}" />

                    <Button Text="Reescanear biblioteca"
                            Command="{Binding RefreshLibraryCommand}"
                            IsVisible="{Binding HasLibraryFolder}"
                            BackgroundColor="{StaticResource Gray900}"
                            TextColor="{StaticResource Secondary}" />
                </VerticalStackLayout>
            </Border>

            <Border IsVisible="{Binding HasTracks}"
                    Padding="0"
                    BackgroundColor="{StaticResource Gray950}"
                    Stroke="{StaticResource Gray600Brush}">
                <CollectionView x:Name="TracksCollectionView"
                                ItemsSource="{Binding Tracks}"
                                SelectedItem="{Binding SelectedTrack, Mode=OneWay}"
                                SelectionMode="Single"
                                SelectionChanged="OnTrackSelectionChanged"
                                ItemSizingStrategy="MeasureFirstItem"
                                VerticalOptions="Fill">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:MediaTrackListItem">
                            <Border Margin="14,10"
                                    Padding="16"
                                    MinimumHeightRequest="74"
                                    BackgroundColor="{StaticResource Gray900}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18">
                                <Grid ColumnDefinitions="*,Auto"
                                      ColumnSpacing="12">
                                    <VerticalStackLayout Spacing="2">
                                        <Label Text="{Binding FileName}"
                                               FontFamily="OpenSansSemibold"
                                               FontSize="16"
                                               TextColor="{StaticResource White}"
                                               LineBreakMode="TailTruncation"
                                               MaxLines="1" />
                                        <Label Text="{Binding Extension}"
                                               FontSize="12"
                                               TextColor="{StaticResource Gray400}" />
                                    </VerticalStackLayout>

                                    <Label Grid.Column="1"
                                           VerticalOptions="Center"
                                           Text="Play"
                                           FontSize="12"
                                           TextColor="{StaticResource Primary}" />
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Border>
        </Grid>

        <Grid Grid.Row="1"
              Margin="24,0,24,24">
            <Border x:Name="MiniPlayerBorder"
                    Background="{StaticResource Gray900Brush}"
                    Padding="16,14"
                    Stroke="{StaticResource Gray600Brush}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnMiniPlayerTapped" />
                </Border.GestureRecognizers>

                <Grid RowDefinitions="Auto,Auto"
                      RowSpacing="10">
                    <Grid ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="14">
                        <Grid WidthRequest="52"
                              HeightRequest="52">
                            <Border BackgroundColor="{StaticResource Primary}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 12"
                                    IsVisible="{Binding HasCurrentArtworkPlaceholder}" />
                            <Image Source="{Binding CurrentArtworkPath}"
                                   Aspect="AspectFill"
                                   IsVisible="{Binding HasCurrentArtwork}" />
                        </Grid>

                        <VerticalStackLayout Grid.Column="1"
                                             Spacing="2"
                                             VerticalOptions="Center">
                            <Label Text="{Binding CurrentTrackTitle}"
                                   FontFamily="OpenSansSemibold"
                                   FontSize="16"
                                   TextColor="{StaticResource White}"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding CurrentArtistName}"
                                   FontSize="12"
                                   TextColor="{StaticResource Gray300}"
                                   LineBreakMode="TailTruncation"
                                   IsVisible="{Binding HasCurrentArtist}" />
                        </VerticalStackLayout>

                        <HorizontalStackLayout Grid.Column="2"
                                               Spacing="8"
                                               VerticalOptions="Center">
                            <Button Text="{Binding ShuffleButtonIcon}"
                                    Command="{Binding ToggleShuffleCommand}"
                                    FontFamily="Segoe UI Symbol"
                                    FontSize="16"
                                    BackgroundColor="{Binding ShuffleButtonBackgroundColor}"
                                    TextColor="{Binding ShuffleButtonTextColor}"
                                    Padding="10,8"
                                    MinimumWidthRequest="48" />
                            <Button Text="{Binding PreviousTrackIcon}"
                                    Command="{Binding PlayPreviousTrackCommand}"
                                    IsEnabled="{Binding CanNavigateTracks}"
                                    FontFamily="Segoe UI Symbol"
                                    FontSize="16"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource White}"
                                    Padding="10,8"
                                    MinimumWidthRequest="48" />
                            <Button Text="{Binding PlayPauseButtonIcon}"
                                    Command="{Binding TogglePlayPauseCommand}"
                                    IsEnabled="{Binding CanTogglePlayback}"
                                    FontFamily="Segoe UI Symbol"
                                    FontSize="16"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource White}"
                                    Padding="12,8"
                                    MinimumWidthRequest="52" />
                            <Button Text="{Binding NextTrackIcon}"
                                    Command="{Binding PlayNextTrackCommand}"
                                    IsEnabled="{Binding CanNavigateTracks}"
                                    FontFamily="Segoe UI Symbol"
                                    FontSize="16"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource White}"
                                    Padding="10,8"
                                    MinimumWidthRequest="48" />
                            <Button Text="{Binding RepeatButtonIcon}"
                                    Command="{Binding CycleRepeatModeCommand}"
                                    FontFamily="Segoe UI Symbol"
                                    FontSize="16"
                                    BackgroundColor="{Binding RepeatButtonBackgroundColor}"
                                    TextColor="{Binding RepeatButtonTextColor}"
                                    Padding="10,8"
                                    MinimumWidthRequest="48" />
                        </HorizontalStackLayout>
                    </Grid>

                    <Grid Grid.Row="1"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="10">
                        <Label Text="{Binding ElapsedTimeText}"
                               VerticalOptions="Center"
                               FontSize="12"
                               TextColor="{StaticResource Gray300}" />
                        <Slider x:Name="PlaybackProgressSlider"
                                Grid.Column="1"
                                Minimum="0"
                                Maximum="{Binding TrackDurationSeconds}"
                                Value="{Binding TrackPositionSeconds}"
                                MinimumTrackColor="{StaticResource Primary}"
                                MaximumTrackColor="{StaticResource Gray600}"
                                ThumbColor="{StaticResource Secondary}"
                                DragStarted="OnPlaybackProgressDragStarted"
                                DragCompleted="OnPlaybackProgressDragCompleted"
                                ValueChanged="OnPlaybackProgressValueChanged" />
                        <Label Grid.Column="2"
                               Text="{Binding DurationTimeText}"
                               VerticalOptions="Center"
                               FontSize="12"
                               TextColor="{StaticResource Gray300}" />
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <Grid x:Name="ExpandedPlayerBorder"
              Grid.RowSpan="2"
              IsVisible="False"
              Opacity="0"
              TranslationY="36"
              BackgroundColor="{StaticResource Black}"
              Padding="28,22,28,32">
            <Grid RowDefinitions="Auto,*,Auto,Auto,Auto"
                  RowSpacing="20"
                  HorizontalOptions="Fill"
                  MaximumWidthRequest="430">
                <Button Text="&#x2304;"
                        Clicked="OnMinimizePlayerClicked"
                        WidthRequest="44"
                        HeightRequest="44"
                        Padding="0"
                        HorizontalOptions="Start"
                        FontSize="26"
                        FontFamily="Segoe UI Symbol"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource White}" />

                <Grid Grid.Row="1"
                      HeightRequest="360"
                      MaximumHeightRequest="380"
                      VerticalOptions="Center">
                    <Border BackgroundColor="{StaticResource Primary}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 16"
                            IsVisible="{Binding HasCurrentArtworkPlaceholder}" />
                    <Image Source="{Binding CurrentArtworkPath}"
                           Aspect="AspectFit"
                           IsVisible="{Binding HasCurrentArtwork}" />
                </Grid>

                <VerticalStackLayout Grid.Row="2"
                                     Spacing="4">
                    <Label Text="{Binding CurrentTrackTitle}"
                           FontFamily="OpenSansSemibold"
                           FontSize="24"
                           TextColor="{StaticResource White}"
                           LineBreakMode="TailTruncation"
                           MaxLines="1" />
                    <Label Text="{Binding CurrentArtistName}"
                           FontSize="15"
                           TextColor="{StaticResource Gray300}"
                           LineBreakMode="TailTruncation"
                           MaxLines="1"
                           IsVisible="{Binding HasCurrentArtist}" />
                </VerticalStackLayout>

                <Grid Grid.Row="3"
                      RowDefinitions="Auto,Auto"
                      RowSpacing="2">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                        <Label Text="{Binding ElapsedTimeText}"
                               FontSize="12"
                               TextColor="{StaticResource Gray300}" />
                        <Label Grid.Column="2"
                               Text="{Binding DurationTimeText}"
                               FontSize="12"
                               TextColor="{StaticResource Gray300}" />
                    </Grid>

                    <Slider x:Name="ExpandedPlaybackProgressSlider"
                            Grid.Row="1"
                            Minimum="0"
                            Maximum="{Binding TrackDurationSeconds}"
                            Value="{Binding TrackPositionSeconds}"
                            MinimumTrackColor="{StaticResource Primary}"
                            MaximumTrackColor="{StaticResource Gray600}"
                            ThumbColor="{StaticResource Secondary}"
                            DragStarted="OnPlaybackProgressDragStarted"
                            DragCompleted="OnExpandedPlaybackProgressDragCompleted"
                            ValueChanged="OnPlaybackProgressValueChanged" />
                </Grid>

                <Grid Grid.Row="4"
                      ColumnDefinitions="*,Auto,Auto,Auto,*"
                      ColumnSpacing="18"
                      HorizontalOptions="Center">
                    <Button Grid.Column="1"
                            Text="{Binding PreviousTrackIcon}"
                            Command="{Binding PlayPreviousTrackCommand}"
                            IsEnabled="{Binding CanNavigateTracks}"
                            WidthRequest="52"
                            HeightRequest="52"
                            Padding="0"
                            FontFamily="Segoe UI Symbol"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Gray300}" />
                    <Button Grid.Column="2"
                            Text="{Binding PlayPauseButtonIcon}"
                            Command="{Binding TogglePlayPauseCommand}"
                            IsEnabled="{Binding CanTogglePlayback}"
                            WidthRequest="64"
                            HeightRequest="64"
                            Padding="0"
                            FontFamily="Segoe UI Symbol"
                            FontSize="24"
                            CornerRadius="32"
                            BackgroundColor="{StaticResource Primary}"
                            TextColor="{StaticResource White}" />
                    <Button Grid.Column="3"
                            Text="{Binding NextTrackIcon}"
                            Command="{Binding PlayNextTrackCommand}"
                            IsEnabled="{Binding CanNavigateTracks}"
                            WidthRequest="52"
                            HeightRequest="52"
                            Padding="0"
                            FontFamily="Segoe UI Symbol"
                            FontSize="20"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource Gray300}" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
